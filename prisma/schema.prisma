// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─── Store Credit ─────────────────────────────────────────────────────────────

model StoreCreditRule {
  id              String   @id @default(uuid())
  shop            String   @unique
  enabled         Boolean  @default(true)
  bonusPercentage Float    @default(10)
  minOrderAmount  Float    @default(0)
  maxCreditAmount Float    @default(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StoreCreditOffer {
  id            String   @id @default(uuid())
  shop          String
  orderId       String
  orderName     String
  returnId      String
  customerId    String?
  refundAmount  Float
  creditAmount  Float
  currencyCode  String   @default("USD")
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shop])
  @@index([returnId])
}

// ─── Return Status Tracking ───────────────────────────────────────────────────
// ReturnStatus values (stored as String for SQLite compatibility):
//   SUBMITTED | UNDER_REVIEW | APPROVED | REJECTED | COMPLETED

model ReturnRequest {
  id              String          @id @default(cuid())
  shop            String
  shopifyReturnId String?         @unique   // gid://shopify/Return/…
  orderName       String
  orderId         String
  customerEmail   String
  customerName    String          @default("")
  reason          String          @default("")
  status          String          @default("SUBMITTED")
  notes           String          @default("")    // internal merchant notes
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  history         StatusHistory[]

  @@index([shop])
  @@index([status])
  @@index([customerEmail])
}

model StatusHistory {
  id              String        @id @default(cuid())
  returnRequestId String
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  fromStatus      String?
  toStatus        String
  note            String        @default("")
  changedAt       DateTime      @default(now())

  @@index([returnRequestId])
}

// ─── Return Rules ─────────────────────────────────────────────────────────────

model ReturnRule {
  id            String   @id @default(uuid())
  shop          String
  name          String
  priority      Int      @default(0)
  active        Boolean  @default(true)

  // Conditions (null = match any)
  productType   String?
  returnReason  String?
  orderValueMin Float?
  orderValueMax Float?

  // Actions
  offerType     String   // "store_credit" | "exchange" | "refund"
  bonusPercent  Float    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shop, active])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model NotificationSetting {
  id              String   @id @default(uuid())
  shop            String   @unique

  // Email
  emailEnabled    Boolean  @default(false)
  emailAddress    String?

  // Slack
  slackEnabled    Boolean  @default(false)
  slackWebhookUrl String?

  // Delivery mode: "immediate" | "digest"
  deliveryMode    String   @default("immediate")
  // For digest: cron hour (0-23) in UTC
  digestHourUtc   Int      @default(9)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NotificationLog {
  id          String   @id @default(uuid())
  shop        String
  channel     String   // "email" | "slack"
  returnId    String
  returnName  String
  orderName   String
  status      String   // "pending" | "sent" | "failed"
  error       String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([shop, status])
}
